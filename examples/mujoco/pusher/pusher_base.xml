<?xml version="1.0" encoding="utf-8"?>
<mujoco model="pusher_environment">
    <compiler inertiafromgeom="true" angle="radian" coordinate="local"/>
    <option timestep="0.01" gravity="0 0 -9.81" iterations="50" integrator="RK4" />
    
    <default>
        <joint armature='0.04' damping="1" limited="true"/>
        <geom friction="1.0 0.1 0.1" density="300" margin="0.001" condim="3" contype="1" conaffinity="1"/>
    </default>
    
    <asset>
        <texture type="skybox" builtin="gradient" rgb1=".4 .6 .8" rgb2=".0 .0 .2" width="800" height="800"/>
        <texture name="groundplane" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 .2 .3" width="300" height="300"/>
        <material name="MatPlane" reflectance="0.5" texture="groundplane" texrepeat="60 60" texuniform="true"/>
    </asset>
    
    <worldbody>
        <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1"/>
        <!-- Table for pusher environment at the right height -->
        <geom name="table" type="plane" pos="0 0.5 -0.325" size="1 1 0.1" contype="1" conaffinity="1" material="MatPlane"/>
        <!-- Ground plane below table -->
        <geom name="ground" type="plane" conaffinity="1" condim="3" material="MatPlane" pos="0 0 -1" size="40 40 40"/>
    </worldbody>
    
    <actuator>
    </actuator>
    
    <sensor>
    </sensor>
    
    <!-- Contact exclusions to prevent self-collision -->
    <contact>
    </contact>
</mujoco>